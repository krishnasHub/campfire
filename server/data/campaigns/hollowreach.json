      "n_gate":    { "x": 52, "y": 16, "terrain": "gate" },
      "n_barrow":  { "x": 62, "y": 8,  "terrain": "barrow" },
      "end_dawn":  { "x": 80, "y": 7,  "terrain": "barrow" },
      "end_hollow":{ "x": 70, "y": 4,  "terrain": "barrow" },
