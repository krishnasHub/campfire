      "name": "Borin Stonehand",
      "race": "Dwarf",
      "class": "Warrior",
      "backstory": "An exile of the deep halls who swore to see the Hollow King's barrow sealed for good. He stands where the line must hold.",
      "stats": { "might": 4, "agility": 1, "wits": 1, "presence": 2, "resolve": 3 },
      "resources": { "hp": 26, "hpMax": 26, "mana": 0, "manaMax": 0, "stamina": 10, "staminaMax": 10 },
      "proficiencies": ["melee", "athletics", "intimidate"],
      "abilities": [
        { "id": "shield_wall", "name": "Shield Wall", "cost": { "stamina": 2 }, "effect": "assist", "desc": "Plant yourself in front of an ally and soak the blow." },
        { "id": "cleave", "name": "Cleave", "cost": { "stamina": 3 }, "effect": "attack:melee", "check": { "skill": "melee" }, "desc": "A heavy two-handed swing." },
        { "id": "roar", "name": "Roar", "cost": { "stamina": 1 }, "effect": "social", "check": { "skill": "intimidate" }, "desc": "A bellow that rattles nerves." }
