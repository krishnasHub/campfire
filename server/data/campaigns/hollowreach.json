      "name": "Kestrel Vane",
      "race": "Human",
      "class": "Warden",
      "backstory": "A borderland warden who has kept Elsvale's roads open for a decade. People follow her because she has never once left them behind.",
      "stats": { "might": 2, "agility": 2, "wits": 2, "presence": 3, "resolve": 2 },
      "resources": { "hp": 20, "hpMax": 20, "mana": 3, "manaMax": 3, "stamina": 8, "staminaMax": 8 },
      "proficiencies": ["melee", "persuade", "tactics"],
      "abilities": [
        { "id": "rally", "name": "Rally", "cost": { "mana": 1 }, "effect": "assist", "desc": "Steady the party — the next ally acts with heart." },
        { "id": "riposte", "name": "Riposte", "cost": { "stamina": 2 }, "effect": "attack:melee", "check": { "skill": "melee" }, "desc": "Turn a blow aside and answer it." },
        { "id": "parley", "name": "Parley", "cost": { "mana": 0 }, "effect": "social", "check": { "skill": "persuade" }, "desc": "Talk a tense moment down." }
      ],
      "gear": [{ "itemId": "longsword" }, { "itemId": "warhorn" }],
