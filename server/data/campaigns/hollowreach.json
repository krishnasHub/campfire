      "name": "Aelith",
      "race": "Wood Elf",
      "class": "Ranger",
      "backstory": "A scout of the Deepwood eaves who has watched the orc-fires creep closer each season. She reads terrain the way others read faces.",
      "stats": { "might": 1, "agility": 3, "wits": 3, "presence": 1, "resolve": 2 },
      "resources": { "hp": 16, "hpMax": 16, "mana": 4, "manaMax": 4, "stamina": 6, "staminaMax": 6 },
      "proficiencies": ["stealth", "perception", "ranged", "lore"],
      "abilities": [
        { "id": "elfsight", "name": "Elf-sight", "cost": { "mana": 0 }, "effect": "scout", "check": { "skill": "perception", "dc": 12 }, "desc": "Perch and read a location at range before committing." },
        { "id": "aimed_shot", "name": "Aimed Shot", "cost": { "stamina": 1 }, "effect": "attack:ranged", "check": { "skill": "ranged" }, "desc": "A patient, precise bowshot." },
        { "id": "fade", "name": "Fade", "cost": { "stamina": 1 }, "effect": "stealth", "check": { "skill": "stealth" }, "desc": "Melt into cover and move unseen." }
      ],
      "gear": [{ "itemId": "longbow" }, { "itemId": "elfsight_lens" }],
      "tags": ["scout", "ranged", "perception"]
    },
    {
