        { "id": "vanish", "name": "Vanish", "cost": { "mana": 1 }, "effect": "stealth", "check": { "skill": "stealth" }, "desc": "A smoke-quick disappearance." },
        { "id": "fast_talk", "name": "Fast-talk", "cost": { "mana": 0 }, "effect": "social", "check": { "skill": "deceive" }, "desc": "A confident lie at speed." }
